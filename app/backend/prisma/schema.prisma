generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String
  createdAt DateTime    @default(now())
  habits    Habit[]
  tasks     ShortTask[]
  projects  Project[]
}

model Habit {
  id        String     @id @default(uuid())
  userId    String
  name      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  logs      HabitLog[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HabitLog {
  id      String @id @default(uuid())
  habitId String
  date    String
  status  String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model ShortTask {
  id            String   @id @default(uuid())
  userId        String
  text          String
  dateAssigned  String
  status        String
  completed     Boolean  @default(false)
  rolloverCount Int      @default(0)
  priority      Int      @default(1)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id            String      @id @default(uuid())
  userId        String
  title         String
  description   String?
  targetEndDate String
  completed     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  milestones    Milestone[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Milestone {
  id        String  @id @default(uuid())
  projectId String
  title     String
  order     Int
  completed Boolean @default(false)
  dueDate   String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
