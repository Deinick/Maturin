generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  passwordHash       String
  email              String          @unique
  name               String
  createdAt          DateTime        @default(now())
  tasks              ShortTask[]
  habits             Habit[]
  projects           Project[]
  projectMemberships ProjectMember[]
  invitesSent        ProjectInvite[]  @relation("InviteCreator")
  changesAuthored    PendingChange[]  @relation("ChangeAuthor")
  changesReviewed    PendingChange[]  @relation("ChangeReviewer")
  assignedMilestones Milestone[]
}

model ShortTask {
  id            String   @id @default(uuid())
  userId        String
  text          String
  description String?
  dateAssigned  String
  status        String
  completed     Boolean  @default(false)
  rolloverCount Int      @default(0)
  priority      Int      @default(1)
  timeEstimate  String?
  category      String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id         String     @id @default(uuid())
  userId     String
  name       String
  isActive   Boolean    @default(true)
  difficulty String     @default("medium")
  activeDays String     @default("1,2,3,4,5,6,7")
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs       HabitLog[]
}

model HabitLog {
  id      String @id @default(uuid())
  habitId String
  date    String
  status  String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model Project {
  id            String          @id @default(uuid())
  userId        String
  title         String
  description   String?
  targetEndDate String?
  completed     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  phases        Phase[]
  members        ProjectMember[]
  invites        ProjectInvite[]
  pendingChanges PendingChange[]
}

model ProjectInvite {
  id           String    @id @default(uuid())
  projectId    String
  invitedEmail String
  role         String
  token        String    @unique
  expiresAt    DateTime
  createdBy    String
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      User      @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
}

model ProjectMember {
  id         String   @id @default(uuid())
  projectId  String
  userId     String
  role       String
  canApprove Boolean  @default(false)
  joinedAt   DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model PendingChange {
  id         String    @id @default(uuid())
  projectId  String
  authorId   String
  entityType String
  entityId   String
  oldData    Json
  newData    Json
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  reviewedBy String?
  reviewedAt DateTime?
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author     User      @relation("ChangeAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reviewer   User?     @relation("ChangeReviewer", fields: [reviewedBy], references: [id])
}

model Phase {
  id         String      @id @default(uuid())
  projectId  String
  title      String
  description String?
  order      Int
  completed  Boolean     @default(false)
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones Milestone[]
}

model Milestone {
  id           String    @id @default(uuid())
  phaseId      String?
  assigneeId   String?
  title        String
  description  String?
  order        Int
  completed    Boolean   @default(false)
  completedAt  DateTime?
  dueDate      String?
  effortRating String?
  blockReason  String?
  phase        Phase?    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  assignee     User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

